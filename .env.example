# ── Neon (Postgres + pgvector) ──────────────────────────────────────────────
# Use the POOLED connection string for serverless. Enable pgvector once with:
#   CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Anthropic (Claude — agent extraction) ───────────────────────────────────
# Option A: call Anthropic directly.
ANTHROPIC_API_KEY="sk-ant-..."
# Optional manual base-URL override for direct calls.
ANTHROPIC_BASE_URL=""
#
# Option B: route Claude through the Neon AI Gateway. Set both vars below
# (populated automatically by `neonctl env pull`). When present, these take
# precedence over ANTHROPIC_API_KEY. The code appends /ai-gateway/anthropic.
NEON_AI_GATEWAY_TOKEN="nt_live_..."
NEON_AI_GATEWAY_BASE_URL="https://br-<branch>-api.<cell>.<region>.aws.neon.tech"

# ── OpenAI (embeddings: text-embedding-3-small) ─────────────────────────────
# Always calls OpenAI directly — the Neon AI Gateway has no OpenAI embeddings
# model, so there is no base-URL override here.
OPENAI_API_KEY="sk-..."

# ── Upstash QStash (crawl fan-out queue) ────────────────────────────────────
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# ── App ─────────────────────────────────────────────────────────────────────
# Protects /api/cron (Vercel sets this header on scheduled invocations).
CRON_SECRET=""
# Public base URL of the deployed app — QStash POSTs crawl jobs to APP_URL/api/crawl.
APP_URL="http://localhost:3000"
