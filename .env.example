# ── Neon (Postgres + pgvector) ──────────────────────────────────────────────
# Use the POOLED connection string for serverless. Enable pgvector once with:
#   CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── Anthropic (Claude — agent extraction) ───────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
# Optional: point at the Neon AI Gateway branch endpoint instead of api.anthropic.com.
# Leave empty to call Anthropic directly.
ANTHROPIC_BASE_URL=""

# ── OpenAI (embeddings: text-embedding-3-small) ─────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_BASE_URL=""

# ── Upstash QStash (crawl fan-out queue) ────────────────────────────────────
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# ── App ─────────────────────────────────────────────────────────────────────
# Protects /api/cron (Vercel sets this header on scheduled invocations).
CRON_SECRET=""
# Public base URL of the deployed app — QStash POSTs crawl jobs to APP_URL/api/crawl.
APP_URL="http://localhost:3000"
